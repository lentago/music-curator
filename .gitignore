# Obsidian editor state if the repo root is opened as a vault. The committed
# worked-example vault under examples/obsidian-vault/ is intentional and keeps
# its own .gitignore, so scope this to the repo root only (leading slash).
/.obsidian/

# Python
__pycache__/
*.pyc

# Harvester secrets must NEVER be committed — they live only on the n8n host
# (/opt/n8n/.env, chmod 600) and in Bitwarden. Belt-and-braces:
.env
*.env

# Raw daily Spotify snapshots land on the NAS, not the repo. Only the periodic
# per-artist roll-ups (data/harvests/YYYY-MM.json) are committed.
data/harvests/spotify-*.json
